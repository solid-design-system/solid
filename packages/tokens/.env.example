# Figma API Token
# Go to your figma account settings > security > personal access tokens > generate a new token
# Create a token with the permissions "Design systems -> File_Variables:Read"
# This has to be done by someone with a Union Investment account
FIGMA_TOKEN=your_figma_token_here

# Figma File ID
# Extract the Figma ID from the URL:
# - For a specific branch: use the URL part after `/branch/`
# - Otherwise: use the value after `/design/`
# Default: VTztxQ5pWG7ARg8hCX6PfR (will be used if not set)
FIGMA_FILE_ID=VTztxQ5pWG7ARg8hCX6PfR
