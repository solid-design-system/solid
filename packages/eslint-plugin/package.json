{
  "name": "@solid-design-system/eslint-plugin",
  "description": "ESLint custom rules for the Solid Design System component library",
  "version": "1.0.4",
  "type": "module",
  "author": {
    "name": "Union Investment"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/solid-design-system/solid.git",
    "directory": "packages/eslint-plugin"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "solid-design-system",
    "Solid Design System"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "jest",
    "verify": "pnpm build && echo '✅ Build verified' && pnpm test && echo '✅ Tests verified'",
    "plop": "plop --plopfile scripts/plop/plopfile.js",
    "postversion": "pnpm build"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@typescript-eslint/rule-tester": "^8.59.3",
    "@typescript-eslint/utils": "^8.59.3",
    "es-html-parser": "^0.3.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "globby": "^16.2.0",
    "jest": "^30.4.2",
    "plop": "^4.0.5",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "5.8.3"
  },
  "peerDependencies": {
    "@html-eslint/parser": "^0.60.0",
    "eslint": "^9.18.0"
  },
  "dependencies": {
    "@html-eslint/parser": "^0.60.0"
  }
}
